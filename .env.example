# ─────────────────────────────────────────────────────────────────────────────
# DevTrack — Variables de entorno para Docker Compose
# En Dokploy: pégalas en Compose service → Environment (sin comillas)
# Localmente: copia este archivo como .env y edita los valores
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=devtrack

# ── Next Auth ─────────────────────────────────────────────────────────────────
# Genera el secreto con: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── URL pública de la app (sin trailing slash) ────────────────────────────────
APP_URL=https://tu-dominio.com

# ── Config de la app (valores por defecto suelen ser suficientes) ─────────────
NEXT_PUBLIC_APP_NAME=DevTrack
NEXT_PUBLIC_WORK_HOURS_START=09:00
NEXT_PUBLIC_WORK_HOURS_END=18:00
NEXT_PUBLIC_LATE_THRESHOLD_MINUTES=15
NEXT_PUBLIC_MIN_HOURS_PER_DAY=6
NEXT_PUBLIC_PASSING_SCORE=3.0
NEXT_PUBLIC_INTERNSHIP_WEEKS=12
